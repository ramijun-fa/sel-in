# ===================================
# 배포 제외 파일 목록 (.gitignore)
# ===================================

# 의존성
node_modules
.pnp
.pnp.js

# 빌드 결과물
dist
dist-ssr
build

# 환경변수 (절대 커밋 금지)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# 인증/크리덴셜 파일 (절대 커밋 금지)
credentials.json
serviceAccount.json
service-account*.json
firebase-adminsdk*.json
*.pem
*.key
*.p12
*.pfx
google-credentials.json

# 에디터 설정
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS 파일
.DS_Store
Thumbs.db

# 로그
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 테스트 커버리지
coverage
